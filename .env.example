# BlockVerse Environment Variables
# Copy this file to .env and fill in the values

# Database (SQLite for dev, PostgreSQL recommended for production)
DATABASE_URL="file:./dev.db"

# Session Security - MUST be at least 32 characters in production
# Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"

# Node Environment
NODE_ENV="development"

# Game Server
GAME_SERVER_PORT=3001

# CORS - Comma-separated list of allowed origins for the game server
ALLOWED_ORIGINS="http://localhost:3000"

# Production Database (uncomment for production)
# DATABASE_URL="postgresql://user:password@localhost:5432/blockverse"

# TURN Server Credentials (REQUIRED for multiplayer to work)
# These are used for NAT traversal so players behind firewalls/routers can connect.
# Without TURN servers, multiplayer will FAIL for most users.
#
# Free options:
#   - Open Relay Project: https://openrelay.metered.ca/ (free tier available)
#   - Metered.ca: https://www.metered.ca/tools/openrelay/ (free TURN)
#   - Twilio: https://www.twilio.com/stun-turn (paid, production-grade)
#
# IMPORTANT: Change these to your own credentials for production!
# The defaults below are public free-tier credentials from OpenRelay.
TURN_SERVER_URL_1="turn:openrelay.metered.ca:80"
TURN_SERVER_USERNAME_1="openrelayproject"
TURN_SERVER_CREDENTIAL_1="openrelayproject"
TURN_SERVER_URL_2="turn:openrelay.metered.ca:443"
TURN_SERVER_USERNAME_2="openrelayproject"
TURN_SERVER_CREDENTIAL_2="openrelayproject"
TURN_SERVER_URL_3="turn:openrelay.metered.ca:443?transport=tcp"
TURN_SERVER_USERNAME_3="openrelayproject"
TURN_SERVER_CREDENTIAL_3="openrelayproject"

# Community Hub (optional - higher rate limits with token)
# A GitHub Personal Access Token with `public_repo` scope for the Community Hub API.
# Without this, the server makes unauthenticated requests (60 req/hr vs 5000 req/hr).
GITHUB_COMMUNITY_TOKEN=""

# BlockVerse Environment Variables
# Copy this file to .env and fill in the values

# Database (SQLite for dev, PostgreSQL recommended for production)
DATABASE_URL="file:./dev.db"

# Session Security - MUST be at least 32 characters in production
# Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-secure-random-string-at-least-32-chars"

# Node Environment
NODE_ENV="development"

# Game Server
GAME_SERVER_PORT=3001

# CORS - Comma-separated list of allowed origins for the game server
ALLOWED_ORIGINS="http://localhost:3000"

# Production Database (uncomment for production)
# DATABASE_URL="postgresql://user:password@localhost:5432/blockverse"
